# Copy to .env (`cp .env.example .env`). Values below are the in-compose
# hostnames used by the api/worker containers.
#
# If you run a tool from your HOST shell (outside Docker) instead of via
# `docker compose exec`, swap the hostnames for the published host ports:
#   DATABASE_URL  -> postgresql+asyncpg://missiongrid:missiongrid@localhost:5432/missiongrid
#   KAFKA_*       -> localhost:19092

DATABASE_URL=postgresql+asyncpg://missiongrid:missiongrid@postgres:5432/missiongrid

KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_COMMANDS_TOPIC=mission.commands.v1
KAFKA_EVENTS_TOPIC=mission.events.v1
KAFKA_TELEMETRY_TOPIC=responder.telemetry.v1
KAFKA_DEAD_LETTER_TOPIC=mission.dead_letter.v1

# Comma-separated list of allowed browser origins (the Next.js frontend).
CORS_ORIGINS=http://localhost:3000

TICK_INTERVAL_MS=500
