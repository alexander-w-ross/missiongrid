# ---------------------------------------------------------------------------
# MissionGrid frontend environment
# Copy to .env.local and adjust. All vars must be NEXT_PUBLIC_* to reach the
# browser.
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend (HTTP). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL of the WebSocket gateway. No trailing slash.
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Run the UI with an in-browser mock backend (no FastAPI/Kafka needed).
# Set to "1" to demo the entire UI standalone. Set to "0" (or remove) to talk
# to the real backend defined above. The mock lives entirely under
# src/lib/mock and is the ONLY place the frontend computes simulation logic.
NEXT_PUBLIC_MOCK=1
